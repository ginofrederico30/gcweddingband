rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /signatures/{clientId}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == clientId
                   || request.auth.token.email == 'gino@gcweddingband.com';
    }
    match /pdfs/{clientId}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == clientId
                   || request.auth.token.email == 'gino@gcweddingband.com';
    }
  }
}
