rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin()       { return request.auth != null && request.auth.token.email == 'gino@gcweddingband.com'; }
    function isArtist()      { return request.auth != null && request.auth.token.email == 'artist@gcweddingband.com'; }
    function isOwner(id)     { return request.auth != null && request.auth.uid == id; }

    match /config/{doc} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }
    match /clients/{id} {
      allow read:  if isAdmin() || isArtist() || isOwner(id);
      allow write: if isAdmin();
    }
    match /contracts/{id} {
      allow read:  if isAdmin() || isArtist() || isOwner(id);
      allow write: if isAdmin() || isOwner(id);
    }
    match /gcp/{id} {
      allow read:  if isAdmin() || isArtist() || isOwner(id);
      allow write: if isAdmin() || isOwner(id);
    }
    match /setlists/{id} {
      allow read:  if isAdmin() || isArtist() || isOwner(id);
      allow write: if isAdmin() || isArtist();
    }
  }
}
